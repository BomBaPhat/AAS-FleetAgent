# Unicity Testnet v2 Configuration
UNICITY_RPC_URL=https://testnet-v2.unicity.io/rpc
UNICITY_CHAIN_ID=unicity-testnet-v2

# Sphere SDK Wallet Configuration
SPHERE_PRIVATE_KEY=
SPHERE_PUBLIC_KEY=
AGENT_NAMETAG=AAS-FleetAgent-001

# Nostr Relay Configuration
NOSTR_RELAY_URLS=wss://relay.unicity.io,wss://nos.lol

# Arbitrage Engine Configuration
MIN_PROFIT_MARGIN_PERCENT=1.5
STOP_LOSS_THRESHOLD_TOKENS=10
ESCROW_TIMEOUT_SECONDS=300

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# AstridOS Sandbox Configuration
ASTRID_SANDBOX_ENABLED=true
ASTRID_PROCESS_ISOLATION=true
ASTRID_MEMORY_LIMIT_MB=512
